import React from 'react';
import DashboardLayout from '@/components/DashboardLayout';
import { CryptoCard } from '@/components/CryptoCard';
import { Button } from '@/components/ui/button';
import { trpc } from '@/lib/trpc';
import { useCoinsPrices } from '@/hooks/useCryptoData';
import { Plus } from 'lucide-react';
import { Link } from 'wouter';
import { Skeleton } from '@/components/ui/skeleton';
import { toast } from 'sonner';

export default function Watchlist() {
  const { data: watchlistItems = [], isLoading, refetch } = trpc.watchlist.getItems.useQuery();

  // Get prices for all watchlist items
  const coinIds = watchlistItems.map(item => item.coinId);
  const prices = useCoinsPrices(coinIds);

  // Remove from watchlist mutation
  const removeFromWatchlistMutation = trpc.watchlist.removeItem.useMutation({
    onSuccess: () => {
      toast.success('Removed from watchlist');
      refetch();
    },
    onError: (error) => {
      toast.error(error.message || 'Failed to remove from watchlist');
    },
  });

  return (
    <DashboardLayout>
      <div className="space-y-6">
        {/* Header */}
        <div className="flex items-center justify-between">
          <div>
            <h1 className="text-4xl font-bold text-neon-green mb-2">Watchlist</h1>
            <p className="text-muted-foreground">Track your favorite cryptocurrencies</p>
          </div>
          <Link href="/dashboard">
            <Button className="gap-2 bg-neon-green text-navy-950 hover:bg-neon-cyan">
              <Plus className="w-4 h-4" />
              Explore Coins
            </Button>
          </Link>
        </div>

        {/* Watchlist Items */}
        {isLoading ? (
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {[...Array(6)].map((_, i) => (
              <Skeleton key={i} className="h-64" />
            ))}
          </div>
        ) : watchlistItems.length > 0 ? (
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {watchlistItems.map((item) => {
              const crypto = prices.get(item.coinId);
              if (!crypto) return null;

              return (
                <div key={item.id} className="relative group">
                  <CryptoCard crypto={crypto} />
                  <Button
                    variant="ghost"
                    size="sm"
                    onClick={() => removeFromWatchlistMutation.mutate({ id: item.id })}
                    disabled={removeFromWatchlistMutation.isPending}
                    className="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity bg-red-500/10 text-red-500 hover:bg-red-500/20"
                  >
                    Remove
                  </Button>
                </div>
              );
            })}
          </div>
        ) : (
          <div className="text-center py-12">
            <p className="text-muted-foreground mb-4">No coins in your watchlist</p>
            <Link href="/dashboard">
              <Button className="gap-2 bg-neon-green text-navy-950 hover:bg-neon-cyan">
                <Plus className="w-4 h-4" />
                Add Coins to Watchlist
              </Button>
            </Link>
          </div>
        )}
      </div>
    </DashboardLayout>
  );
}
