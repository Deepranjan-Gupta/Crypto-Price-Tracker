import React, { createContext, useContext, useState, useEffect, useCallback } from 'react';
import type { Currency, CryptoMarketData } from '@shared/types';
import { getTopCryptos, getFearGreedIndex, getMarketOverview } from '@/services/coingeckoApi';
import type { FearGreedIndex, MarketOverview } from '@shared/types';

interface CryptoContextType {
  currency: Currency;
  setCurrency: (currency: Currency) => void;
  prices: Map<string, CryptoMarketData>;
  setPrices: (prices: CryptoMarketData[]) => void;
  fearGreedIndex: FearGreedIndex | null;
  marketOverview: MarketOverview | null;
  lastUpdated: Date | null;
  isLoading: boolean;
  refreshInterval: number;
  setRefreshInterval: (interval: number) => void;
  refreshPrices: () => Promise<void>;
}

const CryptoContext = createContext<CryptoContextType | undefined>(undefined);

export function CryptoProvider({ children }: { children: React.ReactNode }) {
  const [currency, setCurrency] = useState<Currency>('usd');
  const [prices, setPricesState] = useState<Map<string, CryptoMarketData>>(new Map());
  const [fearGreedIndex, setFearGreedIndex] = useState<FearGreedIndex | null>(null);
  const [marketOverview, setMarketOverview] = useState<MarketOverview | null>(null);
  const [lastUpdated, setLastUpdated] = useState<Date | null>(null);
  const [isLoading, setIsLoading] = useState(false);
  const [refreshInterval, setRefreshInterval] = useState(30); // 30 seconds default

  const refreshPrices = useCallback(async () => {
    setIsLoading(true);
    try {
      const [topCryptos, fearGreed, overview] = await Promise.all([
        getTopCryptos(currency, 100),
        getFearGreedIndex(),
        getMarketOverview(currency),
      ]);

      const priceMap = new Map(topCryptos.map(crypto => [crypto.id, crypto]));
      setPricesState(priceMap);
      setFearGreedIndex(fearGreed);
      setMarketOverview(overview);
      setLastUpdated(new Date());
    } catch (error) {
      console.error('Error refreshing prices:', error);
    } finally {
      setIsLoading(false);
    }
  }, [currency]);

  // Initial load
  useEffect(() => {
    refreshPrices();
  }, [currency, refreshPrices]);

  // Auto-refresh based on interval
  useEffect(() => {
    const interval = setInterval(() => {
      refreshPrices();
    }, refreshInterval * 1000);

    return () => clearInterval(interval);
  }, [refreshInterval, refreshPrices]);

  const setPrices = (newPrices: CryptoMarketData[]) => {
    const priceMap = new Map(newPrices.map(crypto => [crypto.id, crypto]));
    setPricesState(priceMap);
  };

  const value: CryptoContextType = {
    currency,
    setCurrency,
    prices,
    setPrices,
    fearGreedIndex,
    marketOverview,
    lastUpdated,
    isLoading,
    refreshInterval,
    setRefreshInterval,
    refreshPrices,
  };

  return <CryptoContext.Provider value={value}>{children}</CryptoContext.Provider>;
}

export function useCrypto() {
  const context = useContext(CryptoContext);
  if (context === undefined) {
    throw new Error('useCrypto must be used within CryptoProvider');
  }
  return context;
}
